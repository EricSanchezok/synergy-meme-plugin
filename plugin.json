{
  "name": "synergy-meme-plugin",
  "version": "0.3.5",
  "description": "Generate meme images from bundled memegen.link templates.",
  "author": "EricSanchez",
  "homepage": "https://github.com/EricSanchezok/synergy-meme-plugin",
  "repository": "https://github.com/EricSanchezok/synergy-meme-plugin",
  "license": "MIT",
  "keywords": ["synergy-plugin", "meme", "image", "memegen"],
  "icon": "icons/market.svg",
  "engines": {
    "synergy": ">=2.4.3",
    "bun": ">=1.2.0"
  },
  "main": "./src/index.ts",
  "trust": {
    "requestedTier": "declarative",
    "reason": "The plugin contributes runtime tools only and does not load custom Web UI code."
  },
  "permissions": {
    "tools": {
      "filesystem": "none",
      "network": false,
      "shell": false,
      "mcp": "none",
      "task": {
        "agents": ["synergy-meme-planner"],
        "maxRuntimeMs": 120000
      }
    },
    "data": {
      "session": "none",
      "workspace": "none",
      "config": "plugin",
      "secrets": "none"
    },
    "network": {
      "connectDomains": [],
      "resourceDomains": [],
      "frameDomains": []
    },
    "ui": {
      "toolRenderers": false,
      "partRenderers": false,
      "workspacePanels": false,
      "globalPanels": false,
      "settings": false,
      "themes": false,
      "icons": false,
      "routes": false,
      "trustedImport": false,
      "sandboxIframe": false
    },
    "hooks": {
      "events": "none",
      "eventNames": [],
      "toolExecute": "none",
      "permissionAsk": "none",
      "promptTransform": false,
      "compactionTransform": false
    }
  },
  "runtime": {
    "mode": "process",
    "minRuntimeApiVersion": "2.2.0",
    "resources": {
      "memoryMb": 128,
      "startupTimeoutMs": 15000,
      "toolInvocationTimeoutMs": 120000,
      "hookInvocationTimeoutMs": 120000,
      "bridgeRequestTimeoutMs": 120000,
      "taskRunTimeoutMs": 120000,
      "maxConcurrentRequests": 4,
      "maxLogBytesPerMinute": 131072
    }
  },
  "contributes": {
    "tools": [
      {
        "name": "generate_meme",
        "title": "Generate Meme",
        "description": "Generate a meme SVG from a prompt, automatically choosing a bundled template and attaching the primary visual result.",
        "icon": "image",
        "category": "media",
        "kind": "generate",
        "display": {
          "kind": "media-generation",
          "visibility": "media",
          "presentation": "artifact-only",
          "media": {
            "type": "image",
            "aspectRatio": "1:1"
          }
        },
        "capabilities": {
          "filesystem": "none",
          "network": false,
          "shell": false,
          "session": "none",
          "workspace": "none",
          "config": "none"
        }
      },
      {
        "name": "search_meme_templates",
        "title": "Search Meme Templates",
        "description": "Internal helper used by the meme planner to search bundled templates.",
        "icon": "search",
        "category": "media",
        "kind": "search",
        "exposure": { "mode": "internal" },
        "capabilities": {
          "filesystem": "none",
          "network": false,
          "shell": false,
          "session": "none",
          "workspace": "none",
          "config": "none"
        }
      },
      {
        "name": "pick_meme",
        "title": "Pick Meme",
        "description": "Internal helper used by the meme planner to validate the final meme plan.",
        "icon": "check",
        "category": "media",
        "kind": "plan",
        "exposure": { "mode": "internal" },
        "capabilities": {
          "filesystem": "none",
          "network": false,
          "shell": false,
          "session": "none",
          "workspace": "none",
          "config": "none"
        }
      }
    ],
    "agents": [
      {
        "name": "synergy-meme-planner",
        "description": "Hidden planner that selects a meme template and caption plan using internal helper tools.",
        "mode": "subagent",
        "hidden": true,
        "permission": {
          "*": "deny",
          "plugin__synergy-meme-plugin__search_meme_templates": "allow",
          "plugin__synergy-meme-plugin__pick_meme": "allow"
        }
      }
    ]
  }
}
