{
  "name": "synergy-meme-plugin",
  "version": "0.3.5",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "sync:templates": "bun run scripts/sync-templates.ts",
    "verify:templates": "bun run scripts/verify-templates.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "plugin-kit": "bun run scripts/synergy-plugin.ts",
    "dev": "bun run plugin-kit dev",
    "validate:plugin": "bun run plugin-kit validate --runtime-discovery",
    "build:plugin": "bun run plugin-kit build",
    "pack:plugin": "bun run plugin-kit pack",
    "sign:plugin": "bun run plugin-kit sign",
    "entry:plugin": "bun run plugin-kit entry",
    "publish:market": "bun run plugin-kit publish-market --repo https://github.com/EricSanchezok/synergy-meme-plugin",
    "release:check": "bun run verify:templates && bun run typecheck && bun test && bun run validate:plugin && bun run build:plugin && bun run pack:plugin"
  },
  "dependencies": {
    "@ericsanchezok/synergy-plugin": "^2.4.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@ericsanchezok/synergy-plugin-kit": "^2.4.3",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
